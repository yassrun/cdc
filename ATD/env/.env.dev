# ============================================================
# DEV ENVIRONMENT - Development Server
# ============================================================
ENV=dev
APP_NAME=wkf-atd

# ============================================================
# BFF (Backend-for-Frontend) Configuration
# ============================================================
BFF_HOST=localhost
BFF_PORT=9090
BFF_CONTEXT_PATH=/api
BFF_URL=http://${BFF_HOST}:${BFF_PORT}${BFF_CONTEXT_PATH}

# BFF Spring Server
SPRING_PROFILES_ACTIVE=dev
SPRING_SERVER_PORT=${BFF_PORT}
SPRING_SERVER_SERVLET_CONTEXT_PATH=${BFF_CONTEXT_PATH}

# ============================================================
# FRONTEND Configuration
# ============================================================
FRONT_HOST=localhost
FRONT_PORT=4200
FRONT_URL=http://${FRONT_HOST}:${FRONT_PORT}

# Angular Build Environment
ANGULAR_ENV=dev

# ============================================================
# DATABASE Configuration
# ============================================================
DB_HOST=postgres-dev.sgmaroc.root.net
DB_PORT=5432
DB_NAME=workflow_atd_dev
DB_SCHEMA=public
DB_USER=atd_dev_user
DB_PASSWORD=dev_secure_password_here

SPRING_DATASOURCE_URL=jdbc:postgresql://${DB_HOST}:${DB_PORT}/${DB_NAME}?currentSchema=${DB_SCHEMA}
SPRING_DATASOURCE_USERNAME=${DB_USER}
SPRING_DATASOURCE_PASSWORD=${DB_PASSWORD}
SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.PostgreSQLDialect
SPRING_JPA_HIBERNATE_DDL_AUTO=validate

# ============================================================
# KEYCLOAK (OAuth2) Configuration
# ============================================================
KEYCLOAK_HOST=sso-dev.sgmaroc.root.net
KEYCLOAK_PORT=443
KEYCLOAK_REALM=realm_ce_dev
KEYCLOAK_URL=https://${KEYCLOAK_HOST}

SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_JWK_SET_URI=${KEYCLOAK_URL}/realms/${KEYCLOAK_REALM}/protocol/openid-connect/certs
SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_ISSUER_URI=${KEYCLOAK_URL}/realms/${KEYCLOAK_REALM}

# Keycloak Client Configuration
KEYCLOAK_CLIENT_ID=risques-operationnels-bff-dev
KEYCLOAK_CLIENT_SECRET=dev_client_secret_here
KEYCLOAK_GRANT_TYPE=client_credentials

# Frontend Keycloak
KEYCLOAK_JS_URL=${KEYCLOAK_URL}/js/keycloak.js
KEYCLOAK_REALM_URL=${KEYCLOAK_URL}/realms/${KEYCLOAK_REALM}

# ============================================================
# EXTERNAL APIs Configuration
# ============================================================
# GED (Document Management) Service
CORE_API_GED_URL=https://apidev.sgmaroc.root.net/api/support/document-service/v1
CORE_API_GED_TIMEOUT=30000

# Notification Service
CORE_API_NOTIFICATION_URL=https://apidev.sgmaroc.root.net/api-docs/api/support/notification/v1
CORE_API_NOTIFICATION_TIMEOUT=30000

# BPM (Business Process Management) Adapter
CORE_API_BPM_ADAPTER_URL=https://apidev.sgmaroc.root.net/api/ms-bpm-adapter/v1
CORE_API_BPM_ADAPTER_TIMEOUT=30000

# ============================================================
# LOGGING Configuration
# ============================================================
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_SAHAMBANK=INFO
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK=WARN

# ============================================================
# PROXY Configuration (if behind corporate proxy)
# ============================================================
HTTP_PROXY=http://127.0.0.1:3128
HTTPS_PROXY=http://127.0.0.1:3128
NO_PROXY=localhost,127.0.0.1,sgmaroc.root.net
